алг математика(цел a, цел b)
нач
    возврат (a * b) % 10
кон

алг главная()
нач
    вывод "--- Тест Кумир 2.0: Абсолютная Мощь ---"
    
    | 1. Дробные числа и математика
    вещ пи
    пи := 3.1415
    вывод "Число ПИ: ", пи

    | 2. Массивы (Списки) и возвраты из функций
    таб инвентарь
    инвентарь := ["Меч", "Щит", "Зелье"]
    инвентарь[1] := "Броня"
    вывод "Твой инвентарь: ", инвентарь

    цел урон
    урон := математика(5, 7)
    вывод "Урон: ", урон

    | 3. Правильный Ввод Русского Текста
    вывод "Введите ваше имя:"
    лит имя
    имя := ввод()
    вывод "Привет, ", имя, "! Букв в имени: ", длина(имя)

    | 4. Настоящая сеть своими руками (Сырые Сокеты)
    цел сок
    сок := сокет_создать()
    если сокет_подключить(сок, "example.com", 80) = 1 то
        сокет_отправить(сок, "GET / HTTP/1.1\r\nHost: example.com\r\n\r\n")
        лит ответ
        ответ := сокет_получить(сок, 256)
        вывод "\nПервые 256 байт сайта:\n", ответ
    все
    сокет_закрыть(сок)
кон
